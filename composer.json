{
    "name": "statum/safaricom-daraja-sdk",
    "description": "PHP 8.2+ SDK for Safaricom Daraja APIs using Guzzle HTTP client.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-openssl": "*",
        "guzzlehttp/guzzle": "^7.13"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Statum\\Safaricom\\Daraja\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Statum\\Safaricom\\Daraja\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "check": [
            "@test",
            "@analyse"
        ]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
